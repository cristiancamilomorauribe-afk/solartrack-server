# ─── SolarTrack Backend — Variables de entorno ───────────────
# Copia este archivo como .env y rellena los valores

# Puerto del servidor (default: 8080)
PORT=8080

# URL de Firebase Realtime Database (opcional — para sync en la nube)
# Formato: https://TU-PROYECTO-DEFAULT-RTDB.firebaseio.com
FIREBASE_URL=

# Secret de Firebase (opcional — si tienes reglas de seguridad)
FIREBASE_SECRET=
